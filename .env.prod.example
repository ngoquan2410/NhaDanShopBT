# ================================================================
# NhaDanShop — Production Environment Variables
# ================================================================
# HƯỚNG DẪN:
#   1. Copy file này: cp .env.prod.example .env.prod
#   2. Điền thông tin thật vào .env.prod
#   3. TUYỆT ĐỐI không commit .env.prod lên git
# ================================================================

# ── App version (dùng cho docker image tag) ─────────────────────
APP_VERSION=latest

# ── SQL Server ──────────────────────────────────────────────────
# ⚠️  Đổi password mạnh, ít nhất 12 ký tự, có chữ hoa/thường/số/ký tự đặc biệt
MSSQL_SA_PASSWORD=YourStrongPassword@Prod2024!
DB_NAME=nhadanshop

# ── Spring Boot datasource ──────────────────────────────────────
# PROD: sqlserver là tên service trong docker-compose, không đổi
SPRING_DATASOURCE_URL=jdbc:sqlserver://sqlserver:1433;databaseName=nhadanshop;encrypt=true;trustServerCertificate=true
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=YourStrongPassword@Prod2024!

# ── JWT ─────────────────────────────────────────────────────────
# ⚠️  PHẢI đổi thành chuỗi random 64+ ký tự, không để mặc định!
# Tạo bằng: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING_openssl_rand_base64_64
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ── TOTP ────────────────────────────────────────────────────────
TOTP_ISSUER=NhaDanShop

# ── Cloudflare R2 ───────────────────────────────────────────────
R2_ACCOUNT_ID=REMOVED_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=REMOVED_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REMOVED_R2_SECRET_KEY
R2_BUCKET_NAME=nhadanshop-images
R2_PUBLIC_URL=https://pub-ffbbd28b6aa748ccb4cdcd6482609f85.r2.dev

# ── Domain (dùng trong deploy script) ───────────────────────────
DOMAIN=nhadanshop.vn
API_DOMAIN=api.nhadanshop.vn
