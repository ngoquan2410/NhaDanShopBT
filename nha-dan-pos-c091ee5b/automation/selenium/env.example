# Copy to .env.local or export in CI — never commit real secrets.

# Frontend origin (Vite dev server or preview URL)
BASE_URL=http://localhost:5173

# Backend origin for actuator warmup + fixture API (Node fetch). If unset and BASE_URL is :5173/:5174, defaults to http://127.0.0.1:8080. Set to same as BASE_URL only if you insist on proxying every Node call through Vite.
# API_BASE_URL=http://127.0.0.1:8080

# When preview uses port 5174 (5173 busy), add the same origin to Spring:
#   CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# (defaults in application.properties include 5174 after slice — restart bootRun after pull)

# Admin UI login — username field accepts ADMIN_USERNAME or ADMIN_EMAIL
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional storefront user scenarios
USER_USERNAME=
USER_PASSWORD=

# Gate (also accept RUN_FE_BE_E2E=1 in CI)
RUN_AUTOMATION=1

# Suite filter: smoke | storefront | admin | full | regression (default smoke).
# full/regression: runs fixtures-bootstrap.spec.mjs first (seed tồn + combo) — cần BE + Flyway mới nhất (V31 production varchar).
AUTOMATION_SCOPE=smoke

# Comma-separated tags when you prefer env over CLI --tags=a,b
# AUTOMATION_TAGS=
